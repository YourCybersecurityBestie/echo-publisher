{
  "name": "echo-publisher",
  "version": "0.1.0",
  "description": "Echo Publisher — Azure Functions app that turns SSML into MP3 episodes and publishes them to a per-user RSS feed.",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "deploy": "func azure functionapp publish func-echo-publisher --typescript"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@azure/identity": "^4.4.1",
    "@azure/keyvault-secrets": "^4.8.0",
    "@azure/storage-blob": "^12.24.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "applicationinsights": "^3.3.0",
    "fast-xml-parser": "^4.4.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
